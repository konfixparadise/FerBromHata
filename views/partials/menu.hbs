<nav class="ui stackable menu" onclick="toggleMobile()">
    <header class="ui header item"> 
        <a id="logo" href="/" onclick="event.stopPropagation()"> 
            <img src="/bromus-logo.png"> 
        </a>
        <button class="mobile_hamburger_btn">
            <i class="bars icon"></i>
        </button>
    </header>
    <div class="right menu" id="nav_links">
        <a id="home" class="item" href="/"> Home </a>
        <div class="ui dropdown item" id="catalog_box">
            <a id="catalog"  href="/catalog"> Catalog </a> 
            <i class="dropdown icon"></i>
            <div class="menu">
                <a class="item" href="/catalog"> Farm Solutions </a>
                <a class="item" href="/catalog"> Fields Solutions </a>
                <a class="item" href="/catalog"> Other </a>
            </div>
        </div>
        <a id="about" class="item" href="/about"> About </a>
        <a id="contact" class="item" href="#footerlink"> Contact Us</a>
    </div>
</nav>

<script>
    function toggleMobile() {
        if (window.innerWidth < 768) {
            var nav = document.getElementById("nav_links")
            if (nav) nav.classList.toggle("mobile_open")
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        const navLinks = document.getElementById("nav_links")
        const menuHeader = document.querySelector(".ui.header.item")
        const catalogBox = document.getElementById('catalog_box')
        const catalogLink = document.getElementById('catalog')
        const contactLink = document.getElementById('contact')

        if (typeof $ !== 'undefined' && $.fn.dropdown) {
            $('.ui.dropdown').dropdown({
                on: 'hover',
                action: 'hide' 
            })
        }

        document.addEventListener('click', function (e) {
            const mobile = window.innerWidth < 768
            const mobileOpen = navLinks.classList.contains('mobile_open')

            if (mobile && mobileOpen) {
                const clickedInLinks = navLinks.contains(e.target)
                const clickedOnHeader = menuHeader.contains(e.target)

                if (!clickedInLinks && !clickedOnHeader) {
                    navLinks.classList.remove('mobile_open')
                }
                if (clickedInLinks && e.target.tagName === 'A' && e.target !== catalogLink){
                    navLinks.classList.remove('mobile_open')
                }
            }
        })

        if (catalogBox && catalogLink) {
            catalogBox.addEventListener('click', function(e) {
                if (window.innerWidth > 768) {
                    window.location.href = '/catalog'
                } else {
                    e.stopPropagation();
                }
            })
            catalogLink.addEventListener('click', function(e) {
                if (window.innerWidth < 768) {
                    e.preventDefault()
                    e.stopPropagation()
                }
            })
        }
        if(contactLink) {
            contactLink.addEventListener('click', function () {
                setTimeout(() => {
                    window.history.replaceState({}, document.title, window.location.pathname
                )}, 0)
            })
        }

        var rawId = "{{id}}"
        var pageId = (rawId === "/" || rawId === "") ? "home" : rawId.replace("/", "") 
        
        if (pageId === "catalog") { 
            pageId = "catalog_box"; 
            const icon = document.querySelector('#catalog_box .dropdown.icon')
            if (icon) icon.style.display = 'none'
        }

        var element = document.getElementById(pageId)
        if (element) element.classList.add('active')
    }) 

    window.addEventListener('scroll', function () {
        const menu = document.querySelector('.ui.menu')

        if (window.scrollY > 10) {
            menu.classList.add('scrolled')
        } else {
            menu.classList.remove('scrolled')
        }
    })
</script>