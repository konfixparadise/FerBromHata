<div id="productRow{{index}}" class="admin_catalog_row">
    <div class="admin_catalog_info">
        <div class="catalog_thumb">
            <img src="{{picture.url}}" alt="{{title}}">
        </div>
        <div class="catalog_text">
            <h3 class="admin_catalog_title"> {{title}} </h3>
            <p class="admin_catalog_desc"> {{description}} </p>
        </div>
    </div>
    <div class="admin_catalog_actions">
        <button id="showEditProduct{{index}}" type="button" class="admin_btn admin_btn_edit" title="Edit product">
            <i class="pencil icon"></i>
        </button>
        <a class="admin_btn admin_btn_delete" 
           href="/admin/catalogs/{{catalogId}}/products/delete/{{id}}" 
           title="Delete product"
           onclick="return confirm('Delete this product?')">
            <i class="trash icon"></i>
        </a>
    </div>
</div>